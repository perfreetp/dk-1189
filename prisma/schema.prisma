generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  name         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  packingLists PackingList[]
}

model PackingList {
  id             String        @id @default(uuid())
  userId         String
  name           String
  destination    String
  days           Int
  season         String
  transport      String
  accommodation  String
  companions     String
  generatedItems String
  customItems    String        @default("[]")
  isCompleted    Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sharedWith     SharedList[]
}

model SharedList {
  id            String      @id @default(uuid())
  packingListId String
  sharedBy      String
  sharedWith    String
  permission    String
  createdAt     DateTime    @default(now())
  packingList   PackingList @relation(fields: [packingListId], references: [id], onDelete: Cascade)
}

model ItemCategory {
  id          String        @id @default(uuid())
  name        String        @unique
  description String
  icon        String
  items       PackingItem[]
}

model PackingItem {
  id          String        @id @default(uuid())
  categoryId  String
  name        String
  description String?
  priority    String
  weight      Float?
  isLiquid    Boolean       @default(false)
  category    ItemCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}
